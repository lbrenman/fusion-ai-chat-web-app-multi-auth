# ── AUTH MODE ─────────────────────────────────────────────────────────────────
# Controls how the app authenticates to the AI Chat API.
# Options: apikey | clientcredentials | pkce
AUTH_MODE=clientcredentials

# ── AI CHAT API ───────────────────────────────────────────────────────────────
BASE_URL=https://your-api-base-url.com

# ── API KEY (AUTH_MODE=apikey) ────────────────────────────────────────────────
API_KEY_NAME=x-api-key
API_KEY_VALUE=your-api-key-here

# ── CLIENT CREDENTIALS (AUTH_MODE=clientcredentials) ─────────────────────────
TOKEN_URL=https://your-auth-server.com/oauth/token
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# ── PKCE (AUTH_MODE=pkce) ─────────────────────────────────────────────────────
AUTH_URL=https://your-auth-server.com/oauth/authorize
# TOKEN_URL=  (same as above, reuse if on same auth server)
# CLIENT_ID=  (same as above, but must be a public client with auth OFF)
REDIRECT_URI=http://localhost:3000/callback
SCOPE=openid profile email
SESSION_SECRET=change-me-to-a-long-random-string

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3000
